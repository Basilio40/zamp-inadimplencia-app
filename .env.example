# Banco de dados PostgreSQL (Railway provisiona automaticamente)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# URL da aplicação em produção (ex: https://seu-app.up.railway.app)
NEXTAUTH_URL="https://seu-app.up.railway.app"

# Chave secreta para NextAuth - gere uma forte com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-forte-aqui"
