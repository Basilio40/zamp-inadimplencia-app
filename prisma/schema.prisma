generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Loja {
  id          Int      @id @default(autoincrement())
  pda         String?
  bkn         String?  @unique
  cnpj        String?
  nome        String
  cliente     String?
  uf          String?
  regional    String?
  endereco    String?
  escopo      String?  @default("FRIO")
  supervisor  String?
  pcm         String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chamados    Chamado[]
  oscs        OSC[]
  preventivas Preventiva[]
  arts        ART[]
  faturamentos Faturamento[]
}

model Chamado {
  id                Int      @id @default(autoincrement())
  lojaId            Int
  numeroChamado     String?
  pda               String?
  motivo            String?
  status            String?  @default("PENDENTE")
  dataAbertura      DateTime?
  mes               String?
  tecnico           String?
  descricaoServico  String?
  valorProposta     Float?   @default(0)
  oscOsbOsd         String?
  statusEquipamento String?
  observacoes       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  loja              Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  oscs              OSC[]
}

model OSC {
  id                Int      @id @default(autoincrement())
  chamadoId         Int?
  lojaId            Int
  numeroOsc         String?
  status            String?  @default("PENDENTE")
  valor             Float?   @default(0)
  descricao         String?
  cobrancaImediata  Boolean  @default(false)
  createdAt         DateTime @default(now())

  loja              Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  chamado           Chamado? @relation(fields: [chamadoId], references: [id], onDelete: SetNull)
}

model Preventiva {
  id              Int      @id @default(autoincrement())
  lojaId          Int
  mesRef          String?
  ano             Int?     @default(2026)
  tipoManutencao  String?  @default("AR_CONDICIONADO")
  periodicidade   String?  @default("MENSAL")
  dataInicio      DateTime?
  dataTermino     DateTime?
  status          String?  @default("PENDENTE")
  valorFrio       Float?   @default(0)
  valorAr         Float?   @default(0)
  valorTotal      Float?   @default(0)
  pmocStatus      String?
  artVencimento   DateTime?
  artStatus       String?
  nfNumero        String?
  dataPagamento   DateTime?
  proximoCiclo    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  loja            Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
}

model ART {
  id          Int      @id @default(autoincrement())
  lojaId      Int
  osp         String?
  valor       Float?   @default(0)
  tipo        String?
  dataEmissao DateTime?
  vencimento  DateTime?
  status      String?  @default("EM_DIA")
  createdAt   DateTime @default(now())

  loja        Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
}

model Faturamento {
  id              Int      @id @default(autoincrement())
  lojaId          Int
  tipo            String?  @default("CORRETIVA")
  status          String?  @default("PENDENTE")
  nfNumero        String?
  dataPagamento   DateTime?
  proximoCiclo    DateTime?
  valor           Float?   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  loja            Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
}

model Usuario {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  nome            String
  senhaHash       String
  perfil          String   @default("LEITURA")
  supervisorRegional String?
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  lastLogin       DateTime?

  historicos      Historico[]
  uploads         Upload[]
}

model Historico {
  id              Int      @id @default(autoincrement())
  usuarioId       Int?
  tabelaAfetada   String?
  registroId      Int?
  campo           String?
  valorAntigo     String?
  valorNovo       String?
  tipoAcao        String?  @default("EDIT")
  timestamp       DateTime @default(now())

  usuario         Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Upload {
  id              Int      @id @default(autoincrement())
  usuarioId       Int?
  nomeArquivo     String
  tipo            String?
  status          String?  @default("PROCESSANDO")
  linhasProcessadas Int?   @default(0)
  linhasComErro   Int?     @default(0)
  metadados       String?
  dataUpload      DateTime @default(now())

  usuario         Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
}

model Snapshot {
  id          Int      @id @default(autoincrement())
  uploadId    Int?
  tipoDados   String?
  dados       String?
  criadoEm    DateTime @default(now())
}
